{
	"name": "server",
	"version": "0.0.1",
	"main": "lib/index.js",
	"scripts": {
		"dev": "rm -rf lib && babel src --out-dir lib --copy-files --source-maps --include-dotfiles && concurrently \"babel src --out-dir lib --copy-files --source-maps --include-dotfiles --watch\" \"node --watch lib/index.js\"",
		"build": "rm -rf lib && babel src --out-dir lib --copy-files --include-dotfiles",
		"start": "node lib/index.js",
		"lint": "eslint .",
		"test": "jest --verbose"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.78.0",
		"@google/genai": "^1.52.0",
		"an-array-of-english-words": "^2.0.0",
		"bcrypt": "^6.0.0",
		"cloudinary": "^2.9.0",
		"compromise": "^14.15.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"google-auth-library": "^10.5.0",
		"googleapis": "^171.4.0",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.2.1",
		"multer": "^2.1.1",
		"nodemailer": "^8.0.5",
		"sanitize-html": "^2.17.4",
		"yup": "^1.7.1"
	},
	"devDependencies": {
		"@babel/cli": "^7.29.7",
		"@babel/core": "^7.29.7",
		"@babel/eslint-parser": "^7.28.6",
		"@babel/preset-env": "^7.29.7",
		"@eslint/js": "^10.0.1",
		"@types/jest": "^30.0.0",
		"babel-jest": "^30.3.0",
		"babel-plugin-module-resolver": "^5.0.3",
		"concurrently": "^9.2.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.4.0",
		"jest": "^30.4.2",
		"prettier": "^3.8.1"
	},
	"jest": {
		"testMatch": [
			"<rootDir>/tests/**/*.test.js"
		]
